# Warm Burnout Dark -- fzf color scheme
# Source this file AFTER fzf initialization.
# Requires a truecolor terminal.
#
# Palette reference: ../AGENTS.md

export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS}
  --color=fg:#bfbdb6,bg:#1a1510,hl:#ffb454
  --color=fg+:#bfbdb6,bg+:#222018,hl+:#ff8f40
  --color=info:#aea195,prompt:#ff8f40,pointer:#f5c56e
  --color=marker:#b4bc78,spinner:#d4a8b8,header:#8aa8b8
  --color=border:#302a22,separator:#302a22,gutter:#1a1510"
